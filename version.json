{
  "version": "2.0.44",
  "build": "2026-03-18",
  "shell": {
    "script": "userscript/install.js",
    "version": "2.0.44",
    "description": "Public shell loader - handles PAT auth and loads core from private repo"
  },
  "private_repo": {
    "owner": "scrxpted7327",
    "name": "mobius_solver",
    "branch": "main",
    "api_base": "https://api.github.com/repos/scrxpted7327/mobius_solver/contents/userscript/"
  },
  "core": {
    "version": "2.0.44",
    "description": "Main Tampermonkey userscript with ModuleLoader, LMS detection, auto-update"
  },
  "modules": {
    "lib": {
      "config.js": "1.0.0",
      "storage.js": "1.0.0",
      "logger.js": "1.0.0",
      "utils.js": "1.0.0",
      "server-api.js": "1.0.0",
      "notification.js": "1.0.0",
      "progress.js": "1.0.0",
      "element-finder.js": "1.0.0",
      "input-interactor.js": "1.0.0",
      "image-capture.js": "1.0.0",
      "monkey-config.js": "1.0.0",
      "answers-review.js": "1.0.0"
    },
    "lms": {
      "mobius": {
        "version": "1.0.0",
        "status": "stable",
        "modules": ["detector.js", "scraper.js", "dom-handler.js", "solver.js"]
      },
      "smartwork5": {
        "version": "0.1.0",
        "status": "beta",
        "modules": ["detector.js", "scraper.js", "solver.js"]
      },
      "canvas": {
        "version": "0.1.0",
        "status": "beta",
        "modules": ["detector.js", "scraper.js", "solver.js"]
      }
    }
  },
  "lms": {
    "url_patterns": {
      "mobius": ["*.mobius.cloud/*", "*.mobiusplatform.org/*"],
      "smartwork5": ["*.wwnorton.com/smartwork5/*"],
      "canvas": ["*canvas*", "*instructure.com*"]
    }
  },
  "auth": {
    "method": "personal_access_token",
    "storage_key": "lms_solver_github_token",
    "required_scope": "repo",
    "settings_url": "https://github.com/settings/tokens",
    "instructions": "Create a Personal Access Token with 'repo' scope at github.com/settings/tokens"
  }
}
